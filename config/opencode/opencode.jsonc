{
  "$schema": "https://opencode.ai/config.json",
  // Theme configuration
  "theme": "tokyonight",
  "autoupdate": true,
  "formatter": {
    "custom-markdown-formatter": {
      "command": [
        "deno",
        "fmt",
        "$FILE"
      ],
      "extensions": [
        ".md"
      ]
    }
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "REPLACE_WITH_YOUR_CONTEXT7_API_KEY"
      }
    },
    "playwright": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    },
    "chrome-mcp-server": {
      "enabled": true,
      "type": "remote",
      "url": "http://127.0.0.1:12306/mcp"
      // "headers": { "Authorization": "Bearer <token>" } // only if your server needs it
    },
    "nostr": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@nostrbook/mcp@latest"
      ]
    },
    "firecarwl": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.firecrawl.dev/REPLACE_WITH_YOUR_FIRECRAWL_API_KEY/v2/mcp"
    },
    "snyk": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "snyk@latest",
        "mcp",
        "-t",
        "stdio"
      ]
    }
  }
}
